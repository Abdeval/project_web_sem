{
  "name": "knowledge-graph-desktop",
  "version": "1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 5174 --strictPort",
    "dev:electron": "wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "demo:viz": "vite --open"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "cytoscape": "^3.28.1",
    "electron": "^28.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.19.18",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
