{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@kg/visualization": ["../../packages/visualization/src/index"],
      "@kg/visualization/*": ["../../packages/visualization/src/*"],
      "@kg/embeddings": ["../../packages/embeddings/src/index"],
      "@kg/embeddings/*": ["../../packages/embeddings/src/*"],
      "@kg/core/*": ["../../packages/core/src/*"],
      "@assets/*": ["../../assets/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/renderer/**/*"],
  "exclude": ["node_modules", "dist"]
}
