<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/test#"
         xml:base="http://example.org/test"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">

  <!-- Classes -->
  <owl:Class rdf:about="http://example.org/test#ClassA">
    <rdfs:label>ClassA</rdfs:label>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/test#ClassB">
    <rdfs:label>ClassB</rdfs:label>
  </owl:Class>

  <!-- Propriété -->
  <owl:ObjectProperty rdf:about="http://example.org/test#hasPart">
    <rdfs:domain rdf:resource="http://example.org/test#ClassA"/>
    <rdfs:range rdf:resource="http://example.org/test#ClassB"/>
  </owl:ObjectProperty>

</rdf:RDF>